# ---------------------------------------------------------------------------
# Copie para .env e ajuste. O .env NÃO vai para o git (ver .gitignore).
# ---------------------------------------------------------------------------

# Postgres (container) — superusuário usado para migrations e seed
POSTGRES_DB=saas_odonto
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Senha do role da aplicação (não-superusuário, sujeito a RLS)
APP_DB_PASSWORD=app_password

# Conexão da APLICAÇÃO (role app_user, RLS ativo). Usada em runtime.
DATABASE_URL=postgresql+asyncpg://app_user:app_password@db:5432/saas_odonto

# Conexão ADMIN (superusuário). Usada por Alembic (migrations) e pelo seed.
ADMIN_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/saas_odonto

# JWT
JWT_SECRET=troque-este-segredo-bem-longo-em-producao-min-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=SaaS Odonto
ENVIRONMENT=development

# CORS — origens permitidas, separadas por vírgula.
# Em produção, substitua pelo domínio real (ex: https://app.suaclinica.com.br).
# Múltiplos: ALLOWED_ORIGINS=https://app.meudominio.com,https://admin.meudominio.com
ALLOWED_ORIGINS=http://localhost:5173

# Agente de IA (LLM). Deixe "mock" (sem chave) ou use "gemini" com uma chave
# grátis do Google AI Studio (https://aistudio.google.com).
LLM_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Canal de mensagens. "mock" (default) ou "meta" (WhatsApp Cloud API).
# No modo meta, pegue o número de teste + token no developers.facebook.com.
CHANNEL_PROVIDER=mock
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0

# Gateway de pagamento. "mock" (default) ou "mercadopago" (Pix).
# No modo mercadopago, use o Access Token de TESTE (TEST-...) do painel de devs.
BILLING_PROVIDER=mock
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PAYER_EMAIL=test_user@testuser.com

# Calendário externo. "null" (default, no-op) ou "google" (Google Calendar).
# Em modo "google": crie uma Service Account no Google Cloud, baixe credentials.json,
# compartilhe o calendário alvo com o e-mail da SA, e cole o conteúdo JSON aqui
# (em uma linha, com as quebras de linha \n dentro das strings).
CALENDAR_PROVIDER=null
GOOGLE_CALENDAR_ID=primary
GOOGLE_SA_CREDENTIALS_JSON=
